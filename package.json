{
  "name": "@containerbase/istanbul-reports-html",
  "version": "0.0.0-semantic-release",
  "keywords": [
    "coverage",
    "highlight",
    "highlight.js",
    "istanbul",
    "jest",
    "reports",
    "syntax",
    "vitest"
  ],
  "repository": {
    "type": "git",
